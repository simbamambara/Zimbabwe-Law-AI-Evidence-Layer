{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/zimbabwe-2022-evidence-record.schema.json",
  "title": "Zimbabwe Law AI 2022 Evidence Record",
  "description": "Canonical record schema for structured draft, exclusion, and manual-review evidence records.",
  "type": "object",
  "required": [
    "dataset_year",
    "court_family",
    "court_instance",
    "division",
    "record_type",
    "publication_workflow_status",
    "workflow_reason",
    "official_header_classification",
    "document_name",
    "case_name",
    "court",
    "case_number",
    "judgment_number",
    "citation",
    "parties",
    "judges",
    "hearing_date",
    "judgment_date",
    "counsel_and_appearances",
    "subject_area",
    "catchwords_flynote",
    "headnote",
    "facts",
    "issues_for_determination",
    "legal_principles",
    "held_decision_points",
    "ratio_decidendi",
    "obiter_dicta_where_relevant",
    "cases_referred_to",
    "legislation_considered",
    "constitutional_provisions_considered",
    "procedural_history",
    "final_order",
    "full_formatted_judgment_text",
    "reviewer_comments",
    "approval_status",
    "export_history",
    "source_block_sha256",
    "source_block_text",
    "canonical_identity",
    "record_id",
    "source_occurrences",
    "source_occurrence_count",
    "duplicate_detected",
    "record_sha256",
    "dataset_row_number",
    "judgment_number_prefix",
    "judgment_number_int",
    "subject_area_terms",
    "cases_referred_to_terms",
    "legislation_considered_terms",
    "constitutional_provisions_considered_terms"
  ],
  "properties": {
    "record_id": {"type": "string"},
    "canonical_identity": {"type": "string"},
    "court_family": {"type": "string"},
    "court_instance": {"type": "string"},
    "division": {"type": "string"},
    "record_type": {"type": "string"},
    "publication_workflow_status": {"type": "string"},
    "workflow_reason": {"type": "string"},
    "official_header_classification": {"type": "string"},
    "document_name": {"type": "string"},
    "case_name": {"type": "string"},
    "court": {"type": "string"},
    "case_number": {"type": "string"},
    "judgment_number": {"type": "string"},
    "citation": {"type": "string"},
    "parties": {"type": "string"},
    "judges": {"type": "string"},
    "hearing_date": {"type": "string"},
    "judgment_date": {"type": "string"},
    "counsel_and_appearances": {"type": "string"},
    "subject_area": {"type": "string"},
    "catchwords_flynote": {"type": "string"},
    "headnote": {"type": "string"},
    "facts": {"type": "string"},
    "issues_for_determination": {"type": "string"},
    "legal_principles": {"type": "string"},
    "held_decision_points": {"type": "string"},
    "ratio_decidendi": {"type": "string"},
    "obiter_dicta_where_relevant": {"type": "string"},
    "cases_referred_to": {"type": "string"},
    "legislation_considered": {"type": "string"},
    "constitutional_provisions_considered": {"type": "string"},
    "procedural_history": {"type": "string"},
    "final_order": {"type": "string"},
    "full_formatted_judgment_text": {"type": "string"},
    "reviewer_comments": {"type": "string"},
    "approval_status": {"type": "string"},
    "export_history": {"type": "string"},
    "judgment_number_prefix": {"type": "string"},
    "source_block_sha256": {"type": "string"},
    "source_block_text": {"type": "string"},
    "record_sha256": {"type": "string"},
    "dataset_row_number": {"type": "integer", "minimum": 1},
    "dataset_year": {"type": "integer", "const": 2022},
    "judgment_number_int": {"type": ["integer", "null"], "minimum": 0},
    "source_occurrence_count": {"type": "integer", "minimum": 0},
    "duplicate_detected": {"type": "boolean"},
    "subject_area_terms": {"type": "array", "items": {"type": "string"}},
    "cases_referred_to_terms": {"type": "array", "items": {"type": "string"}},
    "legislation_considered_terms": {"type": "array", "items": {"type": "string"}},
    "constitutional_provisions_considered_terms": {"type": "array", "items": {"type": "string"}},
    "source_occurrences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_file_relative",
          "source_filename",
          "source_file_sha256",
          "source_block_sha256",
          "source_block_index"
        ],
        "properties": {
          "source_file_relative": {"type": "string"},
          "source_filename": {"type": "string"},
          "source_file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "source_block_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "source_block_index": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
